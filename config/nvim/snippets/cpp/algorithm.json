  "print128": {
    "prefix": ["print128"],
    "body": [
      "void print128(i128 x) {",
      "    if (x == 0) {",
      "        std::cout << 0;",
      "        return;",
      "    }",
      "    u128 y;",
      "    if (x < 0) {",
      "        std::cout << '-';",
      "        y = u128(-(x + 1)) + 1;",
      "    } else {",
      "        y = x;",
      "    }",
      "    std::string s;",
      "    while (y > 0) {",
      "        s += char('0' + y % 10);",
      "        y /= 10;",
      "    }",
      "    std::ranges::reverse(s);",
      "    std::cout << s;",
      "}",
      "$0"
    ],
    "description": "print signed __int128"
  },
