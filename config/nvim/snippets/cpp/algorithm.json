  "jiangly-style-template": {
    "prefix": ["algo"],
    "body": [
      "#include <bits/stdc++.h>",
      "using i32 = int;",
      "using i64 = long long;",
      "using u32 = unsigned;",
      "using u64 = unsigned long long;",
      "using u128 = unsigned __int128;",
      "using i128 = __int128;",
      "",
      "namespace rgs = std::ranges;",
      "",
      "int main() {",
      "    std::ios::sync_with_stdio(false);",
      "    std::cin.tie(nullptr);",
      "",
      "    $0",
      "",
      "    return 0;",
      "}"
    ],
    "description": "jiangly-style C++ competitive programming template"
  },
  "print128": {
    "prefix": ["print128"],
    "body": [
      "void print128(i128 x) {",
      "    if (x == 0) {",
      "        std::cout << 0;",
      "        return;",
      "    }",
      "    u128 y;",
      "    if (x < 0) {",
      "        std::cout << '-';",
      "        y = u128(-(x + 1)) + 1;",
      "    } else {",
      "        y = x;",
      "    }",
      "    std::string s;",
      "    while (y > 0) {",
      "        s += char('0' + y % 10);",
      "        y /= 10;",
      "    }",
      "    std::ranges::reverse(s);",
      "    std::cout << s;",
      "}",
      "$0"
    ],
    "description": "print signed __int128"
  },
  "power-of-two-i128": {
    "prefix": ["p2", "pow2"],
    "body": [
      "std::vector<${1|i128,i64,int|}> p2(${2:n} + 1);",
      "p2[0] = 1;",
      "for (int i = 1; i <= ${2:n}; i++) {",
      "    p2[i] = p2[i - 1] * 2;",
      "}",
      "$0"
    ],
    "description": "precompute powers of two"
  },
  "cin-mat": {
    "prefix": ["cin-mat"],
    "body": [
      "int ${1:rows}, ${2:cols};",
      "std::cin >> ${1:rows} >> ${2:cols};",
      "std::vector ${4:matrix}(${1:rows}, std::vector<${3|i128,i64,int|}>(${2:cols}));",
      "for (int i = 0; i < ${1:rows}; i++) {",
      "    for (int j = 0; j < ${2:cols}; j++) {",
      "        std::cin >> ${4:matrix}[i][j];",
      "    }",
      "}",
      "$0"
    ],
    "description": "read a matrix from standard input"
  },
  "bigint": {
    "prefix": ["bigint", "BigInt"],
    "body": [
      "constexpr int N = ${1:1000};",
      "",
      "struct BigInt {",
      "    std::array<int, N> a{};",
      "",
      "    BigInt(int x = 0) {",
      "        for (int i = 0; x > 0; i++) {",
      "            a[i] = x % 10;",
      "            x /= 10;",
      "        }",
      "    }",
      "",
      "    BigInt &operator*=(int x) {",
      "        long long carry = 0;",
      "        for (int i = 0; i < N; i++) {",
      "            long long v = 1LL * a[i] * x + carry;",
      "            a[i] = v % 10;",
      "            carry = v / 10;",
      "        }",
      "        return *this;",
      "    }",
      "",
      "    BigInt &operator/=(int x) {",
      "        long long rem = 0;",
      "        for (int i = N - 1; i >= 0; i--) {",
      "            long long v = rem * 10 + a[i];",
      "            a[i] = v / x;",
      "            rem = v % x;",
      "        }",
      "        return *this;",
      "    }",
      "",
      "    BigInt &operator+=(const BigInt &x) {",
      "        int carry = 0;",
      "        for (int i = 0; i < N; i++) {",
      "            int v = a[i] + x.a[i] + carry;",
      "            a[i] = v % 10;",
      "            carry = v / 10;",
      "        }",
      "        return *this;",
      "    }",
      "};",
      "",
      "std::ostream &operator<<(std::ostream &os, const BigInt &x) {",
      "    int t = N - 1;",
      "    while (t > 0 && x.a[t] == 0) {",
      "        t--;",
      "    }",
      "    for (int i = t; i >= 0; i--) {",
      "        os << x.a[i];",
      "    }",
      "    return os;",
      "}",
      "$0"
    ],
    "description": "fixed-size decimal BigInt"
  }
}
