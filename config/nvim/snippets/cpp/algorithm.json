  "bigint": {
    "prefix": ["bigint", "BigInt"],
    "body": [
      "template<int N = ${1:1000}, int BASE = ${2:10}>",
      "struct BigInt {",
      "    static_assert(BASE >= 2 && BASE <= 1000000000);",
      "",
      "    using i64 = long long;",
      "    using u32 = unsigned;",
      "    using u64 = unsigned long long;",
      "    using u128 = unsigned __int128;",
      "    using i128 = __int128;",
      "",
      "    std::array<int, N> a{};",
      "",
      "    BigInt(i64 x = 0) {",
      "        *this = x;",
      "    }",
      "",
      "    BigInt(const std::string &s) {",
      "        read(s);",
      "    }",
      "",
      "    BigInt &operator=(i64 x) {",
      "        assert(x >= 0);",
      "        a.fill(0);",
      "        for (int i = 0; i < N && x > 0; i++) {",
      "            a[i] = x % BASE;",
      "            x /= BASE;",
      "        }",
      "        return *this;",
      "    }",
      "",
      "    void read(const std::string &s) {",
      "        a.fill(0);",
      "        for (char c : s) {",
      "            if (std::isdigit(static_cast<unsigned char>(c))) {",
      "                *this *= 10;",
      "                *this += c - '0';",
      "            }",
      "        }",
      "    }",
      "",
      "    explicit operator bool() const {",
      "        return std::ranges::any_of(a, [](int x) {",
      "            return x != 0;",
      "        });",
      "    }",
      "",
      "    int cmp(const BigInt &x) const {",
      "        for (int i = N - 1; i >= 0; i--) {",
      "            if (a[i] != x.a[i]) {",
      "                return a[i] < x.a[i] ? -1 : 1;",
      "            }",
      "        }",
      "        return 0;",
      "    }",
      "",
      "    [[nodiscard]] std::string to_string() const {",
      "        if (!*this) {",
      "            return \"0\";",
      "        }",
      "        BigInt x = *this;",
      "        std::string s;",
      "        while (x) {",
      "            s += char('0' + x % 10);",
      "            x /= 10;",
      "        }",
      "        std::ranges::reverse(s);",
      "        return s;",
      "    }",
      "",
      "    BigInt &operator+=(int x) {",
      "        assert(x >= 0);",
      "        i64 carry = x;",
      "        for (int i = 0; i < N && carry > 0; i++) {",
      "            i64 v = a[i] + carry;",
      "            a[i] = v % BASE;",
      "            carry = v / BASE;",
      "        }",
      "        return *this;",
      "    }",
      "",
      "    BigInt &operator+=(const BigInt &x) {",
      "        int carry = 0;",
      "        for (int i = 0; i < N; i++) {",
      "            int v = a[i] + x.a[i] + carry;",
      "            a[i] = v % BASE;",
      "            carry = v / BASE;",
      "        }",
      "        return *this;",
      "    }",
      "",
      "    BigInt &operator-=(const BigInt &x) {",
      "        assert(cmp(x) >= 0);",
      "        int borrow = 0;",
      "        for (int i = 0; i < N; i++) {",
      "            int v = a[i] - x.a[i] - borrow;",
      "            if (v < 0) {",
      "                v += BASE;",
      "                borrow = 1;",
      "            } else {",
      "                borrow = 0;",
      "            }",
      "            a[i] = v;",
      "        }",
      "        return *this;",
      "    }",
      "",
      "    BigInt &operator*=(i64 x) {",
      "        assert(x >= 0);",
      "        i128 carry = 0;",
      "        for (int i = 0; i < N; i++) {",
      "            i128 v = i128(a[i]) * x + carry;",
      "            a[i] = int(v % BASE);",
      "            carry = v / BASE;",
      "        }",
      "        return *this;",
      "    }",
      "",
      "    BigInt &operator*=(const BigInt &x) {",
      "        BigInt res;",
      "        for (int i = 0; i < N; i++) {",
      "            if (a[i] == 0) {",
      "                continue;",
      "            }",
      "            i128 carry = 0;",
      "            for (int j = 0; i + j < N; j++) {",
      "                i128 v = res.a[i + j] + carry + i128(a[i]) * x.a[j];",
      "                res.a[i + j] = int(v % BASE);",
      "                carry = v / BASE;",
      "            }",
      "        }",
      "        return *this = res;",
      "    }",
      "",
      "    BigInt &operator/=(i64 x) {",
      "        assert(x > 0);",
      "        i128 rem = 0;",
      "        for (int i = N - 1; i >= 0; i--) {",
      "            i128 v = rem * BASE + a[i];",
      "            a[i] = int(v / x);",
      "            rem = v % x;",
      "        }",
      "        return *this;",
      "    }",
      "",
      "    i64 operator%(i64 x) const {",
      "        assert(x > 0);",
      "        i128 rem = 0;",
      "        for (int i = N - 1; i >= 0; i--) {",
      "            rem = (rem * BASE + a[i]) % x;",
      "        }",
      "        return i64(rem);",
      "    }",
      "",
      "    friend BigInt operator+(BigInt a, const BigInt &b) {",
      "        return a += b;",
      "    }",
      "",
      "    friend BigInt operator-(BigInt a, const BigInt &b) {",
      "        return a -= b;",
      "    }",
      "",
      "    friend BigInt operator*(BigInt a, i64 b) {",
      "        return a *= b;",
      "    }",
      "",
      "    friend BigInt operator*(i64 a, BigInt b) {",
      "        return b *= a;",
      "    }",
      "",
      "    friend BigInt operator*(BigInt a, const BigInt &b) {",
      "        return a *= b;",
      "    }",
      "",
      "    friend BigInt operator/(BigInt a, i64 b) {",
      "        return a /= b;",
      "    }",
      "",
      "    friend bool operator==(const BigInt &a, const BigInt &b) {",
      "        return a.a == b.a;",
      "    }",
      "",
      "    friend bool operator!=(const BigInt &a, const BigInt &b) {",
      "        return !(a == b);",
      "    }",
      "",
      "    friend bool operator<(const BigInt &a, const BigInt &b) {",
      "        return a.cmp(b) < 0;",
      "    }",
      "",
      "    friend bool operator>(const BigInt &a, const BigInt &b) {",
      "        return b < a;",
      "    }",
      "",
      "    friend bool operator<=(const BigInt &a, const BigInt &b) {",
      "        return !(b < a);",
      "    }",
      "",
      "    friend bool operator>=(const BigInt &a, const BigInt &b) {",
      "        return !(a < b);",
      "    }",
      "",
      "    friend std::istream &operator>>(std::istream &is, BigInt &x) {",
      "        std::string s;",
      "        is >> s;",
      "        x.read(s);",
      "        return is;",
      "    }",
      "",
      "    friend std::ostream &operator<<(std::ostream &os, const BigInt &x) {",
      "        return os << x.to_string();",
      "    }",
      "};",
      "$0"
    ],
    "description": "fixed-size nonnegative BigInt with configurable base"
  }
}
