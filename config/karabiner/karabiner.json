{
  "profiles": [
    {
      "name": "Default profile",
      "complex_modifications": {
        "rules": [
          {
            "description": "Caps Lock to Control (held), Escape (tapped)",
            "manipulators": [
              {
                "type": "basic",
                "from": { "key_code": "caps_lock", "modifiers": { "optional": ["any"] } },
                "to": [{ "key_code": "left_control" }],
                "to_if_alone": [{ "key_code": "escape" }]
              }
            ]
          },
          {
            "description": "Tab Layer (Navigation/Symbols)",
            "manipulators": [
              {
                "type": "basic",
                "from": { "key_code": "tab", "modifiers": { "optional": ["any"] } },
                "to": [{ "set_variable": { "name": "tab_layer", "value": 1 } }],
                "to_after_key_up": [{ "set_variable": { "name": "tab_layer", "value": 0 } }],
                "to_if_alone": [{ "key_code": "tab" }]
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "q" },
                "to": [{ "key_code": "f12", "modifiers": ["left_control"] }]
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "p" },
                "to": [{ "key_code": "print_screen" }]
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "h" },
                "to": [{ "key_code": "left_arrow" }]
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "j" },
                "to": [{ "key_code": "down_arrow" }]
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "k" },
                "to": [{ "key_code": "up_arrow" }]
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "l" },
                "to": [{ "key_code": "right_arrow" }]
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "delete_or_backspace" },
                "to": [{ "key_code": "delete_forward" }]
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "a", "modifiers": { "mandatory": ["shift"] } },
                "to": [
                  { "key_code": "u", "modifiers": ["left_option"] },
                  { "key_code": "a", "modifiers": ["shift"] }
                ],
                "description": "tab + shift + a -> Ä"
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "a" },
                "to": [{ "key_code": "u", "modifiers": ["left_option"] }, { "key_code": "a" }],
                "description": "tab + a -> ä"
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "u", "modifiers": { "mandatory": ["shift"] } },
                "to": [
                  { "key_code": "u", "modifiers": ["left_option"] },
                  { "key_code": "u", "modifiers": ["shift"] }
                ],
                "description": "tab + shift + u -> Ü"
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "u" },
                "to": [{ "key_code": "u", "modifiers": ["left_option"] }, { "key_code": "u" }],
                "description": "tab + u -> ü"
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "o", "modifiers": { "mandatory": ["shift"] } },
                "to": [
                  { "key_code": "u", "modifiers": ["left_option"] },
                  { "key_code": "o", "modifiers": ["shift"] }
                ],
                "description": "tab + shift + o -> Ö"
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "o" },
                "to": [{ "key_code": "u", "modifiers": ["left_option"] }, { "key_code": "o" }],
                "description": "tab + o -> ö"
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "s", "modifiers": { "mandatory": ["shift"] } },
                "to": [{ "key_code": "b", "modifiers": ["left_option"] }],
                "description": "tab + shift + s -> ẞ"
              },
              {
                "conditions": [{ "type": "variable_if", "name": "tab_layer", "value": 1 }],
                "type": "basic",
                "from": { "key_code": "s" },
                "to": [{ "key_code": "s", "modifiers": ["left_option"] }],
                "description": "tab + s -> ß"
              }
            ]
          }
        ]
      },
      "selected": true
    }
  ]
}
