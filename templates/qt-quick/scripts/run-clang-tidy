#!/usr/bin/env bash
set -euo pipefail

project_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
build_dir="$project_root/.cache/clang-tidy"

cmake --fresh --preset dev -B "$build_dir" >/dev/null
cmake -E rm -f "$build_dir/.ninja_deps" "$build_dir/.ninja_log"
cmake --build "$build_dir" >/dev/null

if (($# == 0)); then
  mapfile -t source_files < <(find "$project_root/src" "$project_root/tests" -type f -name '*.cpp')
else
  source_files=("$@")
fi

clang-tidy -p "$build_dir" --warnings-as-errors='*' "${source_files[@]}"
